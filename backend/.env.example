# Multi-LLM Configuration
# The system tries these in order: Gemini → OpenAI → Groq → Rule-based Fallback

# Gemini API Key (Primary - Free, Fast)
# Get it from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Key (Secondary - Paid, High Quality)
# Get it from: https://platform.openai.com/api-keys
# Used if Gemini fails or quota exceeded
OPENAI_API_KEY=your_openai_api_key_here

# Groq API Key (Tertiary - Free, Very Fast)
# Get it from: https://console.groq.com/keys
# Used if both Gemini and OpenAI fail
GROQ_API_KEY=your_groq_api_key_here

# MongoDB (Optional - not currently used)
MONGODB_URL=mongodb://localhost:27017
